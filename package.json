{
  "name": "minch-cli",
  "version": "0.2.0",
  "description": "A slick terminal torrent finder for public sources, powered by a scoped Cardigann interpreter and Prowlarr's public indexer definitions.",
  "type": "module",
  "bin": {
    "minch": "./dist/cli.cjs"
  },
  "files": [
    "dist",
    "definitions",
    "docs"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx src/index.tsx",
    "build": "tsup",
    "postbuild": "node scripts/cli-entry.mjs",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "spike:discovery": "tsx scripts/discovery-contract-spike.ts",
    "validate:discovery-india": "tsx scripts/discovery-india-validation.ts",
    "beta:discovery": "tsx scripts/discovery-beta.ts",
    "review:discovery": "tsx scripts/discovery-relevance-review.ts",
    "review:discovery-handoff": "tsx scripts/discovery-search-handoff-review.ts",
    "acceptance:discovery": "tsx scripts/discovery-acceptance.ts",
    "refresh:discovery-physical": "tsx scripts/discovery-physical-refresh.ts",
    "sync:definitions": "tsx scripts/sync-definitions.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "torrent",
    "torrent-search",
    "magnet",
    "prowlarr",
    "cardigann",
    "torznab",
    "indexer",
    "tui",
    "terminal",
    "cli",
    "ink",
    "public"
  ],
  "author": "minch",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "cheerio": "^1.0.0",
    "env-paths": "^3.0.0",
    "fast-xml-parser": "^5.9.3",
    "ink": "^5.1.0",
    "react": "^18.3.1",
    "undici": "^6.21.0",
    "yaml": "^2.6.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.12",
    "ink-testing-library": "^4.0.0",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
