# Variable names only. This file intentionally contains no credential values.
# minch-cli reads process.env; it does not automatically load this file.

TMDB_READ_TOKEN=

# Reserved until Trakt gives written approval for this application. See ADR 001.
TRAKT_CLIENT_ID=

# Direct Movie of the Night developer-platform key only.
STREAMING_AVAILABILITY_API_KEY=

# Apify token for the India OTT Popular feed.
APIFY_API_TOKEN=

# Firecrawl key for the TamilMV latest Discover feed.
FIRECRAWL_API_KEY=

# Optional user-owned key for exact IMDb enrichment through MDBList.
MDBLIST_API_KEY=
